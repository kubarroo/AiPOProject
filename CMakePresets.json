{
  "version": 6,
  "configurePresets": [
    {
      "name": "clang-debug",
      "displayName": "Clang Debug",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/clang-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++"
      }
    },
    {
      "name": "gcc-linux-debug",
      "displayName": "GCC Linux Debug",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/gcc-linux-debug",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++"
      }
    },
    {
        "name": "clang-macos-homebrew-debug",
        "generator": "Ninja",
        "binaryDir": "${sourceDir}/build/clang-macos-debug",
        "cacheVariables": {
            "CMAKE_BUILD_TYPE": "Debug",
            "CMAKE_C_COMPILER": "/opt/homebrew/opt/llvm/bin/clang",
            "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++"
        }
    }
  ],
  "buildPresets": [
    {
      "name": "clang-debug",
      "configurePreset": "clang-debug"
    },
    {
      "name": "gcc-linux-debug",
      "configurePreset": "gcc-linux-debug"
    },
    {
      "name": "clang-macos-homebrew-debug",
      "configurePreset": "clang-macos-homebrew-debug"
    }
  ]
}
